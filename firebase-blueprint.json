{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "selectedArtists": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "onboardingCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt", "updatedAt"]
    },
    "Like": {
      "title": "Liked Song",
      "description": "A song liked by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "songId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "songId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/likes/{likeId}": {
      "schema": "Like",
      "description": "User's liked songs"
    }
  }
}
