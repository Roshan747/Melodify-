rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      let requiredFields = ['uid', 'email', 'displayName', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(requiredFields)
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 100
        && (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 1024))
        && (data.get('selectedArtists', null) == null || (data.selectedArtists is list))
        && (data.get('onboardingCompleted', null) == null || (data.onboardingCompleted is bool))
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (incoming().get('selectedArtists', null) == null || (incoming().selectedArtists is list))
        && (incoming().get('onboardingCompleted', null) == null || (incoming().onboardingCompleted is bool))
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'selectedArtists', 'onboardingCompleted']);
      
      match /likes/{likeId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) 
          && incoming().userId == request.auth.uid
          && incoming().createdAt == request.time
          && incoming().keys().size() == 3;
        allow delete: if isOwner(userId);
      }
    }
  }
}
